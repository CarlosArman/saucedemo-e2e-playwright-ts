{
  "name": "saucedemo-e2e-playwright-ts",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "report:clean": "rimraf reports",
    "test:bdd": "npm run report:clean && cucumber-js --config cucumber.cjs",
    "test:bdd:qa:chrome": "npm run report:clean && cross-env TEST_ENV=qa BROWSER=chromium cucumber-js --config cucumber.cjs",
    "test:bdd:qa:firefox": "npm run report:clean && cross-env TEST_ENV=qa BROWSER=firefox cucumber-js --config cucumber.cjs",
    "test:bdd:prod:chrome": "npm run report:clean && cross-env TEST_ENV=prod BROWSER=chromium cucumber-js --config cucumber.cjs",
    "allure:generate": "allure generate reports/allure-results -o reports/allure-report --clean",
    "allure:open": "allure open reports/allure-report"

  },
  "keywords": [],
  "author": "Carlos Ruiz",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@cucumber/messages": "^32.3.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure": "^3.5.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-js-commons": "^3.7.1",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "undici-types": "^7.19.2"
  }
}
